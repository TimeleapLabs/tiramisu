{
  "scopeName": "source.tiramisu",
  "name": "Tiramisu",
  "patterns": [
    {
      "include": "#atom"
    }
  ],
  "repository": {
    "atom": {
      "patterns": [
        {
          "include": "#backslash-escape"
        },
        {
          "include": "#escape"
        },
        {
          "include": "#mermaid-blocks"
        },
        {
          "include": "#escaped-function"
        },
        {
          "include": "#bold"
        },
        {
          "include": "#italic"
        },
        {
          "include": "#functions"
        },
        {
          "include": "#link"
        },
        {
          "include": "#string"
        }
      ]
    },
    "backslash-escape": {
      "match": "\\\\[\\\\{}\\[\\],=\"]",
      "name": "constant.character.escape.tiramisu"
    },
    "escaped-function": {
      "match": "\\\\([a-zA-Z]\\w*)",
      "name": "constant.character.escape.tiramisu"
    },
    "link": {
      "match": "(https?|ftp)://[^ \\]\\[]+",
      "name": "markup.underline.link"
    },
    "string": {
      "begin": "(\"{1,})",
      "end": "\\1",
      "name": "string.quoted.double.tiramisu",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.tiramisu"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "begin": "([a-zA-Z]\\w*)\\s*\\{",
          "end": "\\}",
          "captures": {
            "1": {
              "name": "entity.name.function.tiramisu"
            }
          },
          "patterns": [
            {
              "include": "#atom"
            },
            {
              "include": "#parameters"
            }
          ]
        }
      ]
    },
    "parameters": {
      "match": "(\\w+)\\s*=\\s*",
      "captures": {
        "1": {
          "name": "variable.parameter.language.tiramisu"
        }
      }
    },
    "mermaid-blocks": {
      "begin": "(mermaid)\\s*\\{",
      "beginCaptures": {
        "1": {
          "name": "entity.name.function.mermaid"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.block.end.mermaid"
        }
      },
      "contentName": "meta.embedded.mermaid",
      "patterns": [
        {
          "begin": "(^|\\G)(\\s*)(.*)",
          "while": "(^|\\G)(?!\\})",
          "patterns": [
            {
              "contentName": "meta.embedded.block.mermaid",
              "include": "source.mermaid"
            }
          ]
        }
      ]
    },
    "bold": {
      "begin": "(bold)\\s*\\{",
      "end": "\\}",
      "beginCaptures": {
        "1": {
          "name": "entity.name.function.tiramisu"
        }
      },
      "name": "markup.bold.tiramisu",
      "patterns": [
        {
          "include": "#atom"
        },
        {
          "include": "#parameters"
        }
      ]
    },
    "italic": {
      "begin": "(italic)\\s*\\{",
      "end": "\\}",
      "beginCaptures": {
        "1": {
          "name": "entity.name.function.tiramisu"
        }
      },
      "name": "markup.italic.tiramisu",
      "patterns": [
        {
          "include": "#atom"
        },
        {
          "include": "#parameters"
        }
      ]
    },
    "escape": {
      "begin": "(escape)\\s*\\{",
      "end": "\\}",
      "beginCaptures": {
        "1": {
          "name": "entity.name.function.tiramisu"
        }
      },
      "name": "markup.escaped.tiramisu",
      "patterns": [
        {
          "match": ".*"
        }
      ]
    }
  }
}
